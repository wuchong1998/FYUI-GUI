prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: cairo-gobject
Description: cairo-gobject for cairo graphics library
Version: 1.18.4

Libs: "-L${libdir}" -lcairo-gobject -lgdi32 -lmsimg32 -ldwrite -ld2d1 -lwindowscodecs
Requires: cairo, glib-2.0 >=  2.14, gobject-2.0, zlib, libpng >=  1.4.0, fontconfig >=  2.13.0, freetype2 >=  23.0.17, pixman-1 >=  0.40.0
Cflags: "-I${includedir}/cairo" -DCAIRO_WIN32_STATIC_BUILD
