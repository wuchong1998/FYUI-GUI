prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: cairo
Description: Multi-platform 2D graphics library
Version: 1.18.4

Libs: "-L${libdir}" -lcairo -lgdi32 -lmsimg32 -ldwrite -ld2d1 -lwindowscodecs
Requires: zlib, libpng >=  1.4.0, fontconfig >=  2.13.0, freetype2 >=  23.0.17, pixman-1 >=  0.40.0
Cflags: "-I${includedir}/cairo"
