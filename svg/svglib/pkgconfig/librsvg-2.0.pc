prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

svgz_supported=true
css_supported=true

Name: librsvg
Description: library that renders svg files
Version: 2.40.20

Libs: "-L${libdir}" -lrsvg-2
Requires: glib-2.0 gio-2.0 gdk-pixbuf-2.0 cairo libxml-2.0 pangocairo pangoft2 cairo-png libcroco-0.6 gthread-2.0 gmodule-2.0 gobject-2.0 gio-windows-2.0 fontconfig
Cflags: "-I${includedir}/librsvg-2.0"
